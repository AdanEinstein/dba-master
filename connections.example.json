{
  "my_conn": {
    "engine": "oracle",
    "user": "${DBA_MY_CONN_USER}",
    "password": "${DBA_MY_CONN_PASS}",
    "connectString": "${DBA_MY_CONN_CS}",
    "thick": false,
    "poolMax": 8,
    "readOnly": true,
    "schemaFilter": ["APP"]
  },
  "my_pg": {
    "engine": "postgres",
    "connectString": "${DBA_MY_PG_CS}",
    "poolMax": 8,
    "readOnly": true,
    "schemaFilter": ["public"]
  },
  "via_bastion": {
    "engine": "postgres",
    "connectString": "${DBA_VIA_BASTION_CS}",
    "tunnel": {
      "type": "ssh",
      "host": "bastion.example.com",
      "port": 22,
      "user": "${DBA_VIA_BASTION_TUNNEL_USER}",
      "privateKey": "${DBA_VIA_BASTION_TUNNEL_KEY}"
    }
  },
  "via_socks": {
    "engine": "oracle",
    "user": "${DBA_VIA_SOCKS_USER}",
    "password": "${DBA_VIA_SOCKS_PASS}",
    "connectString": "${DBA_VIA_SOCKS_CS}",
    "tunnel": { "type": "socks", "url": "${DBA_VIA_SOCKS_TUNNEL_PROXY_URL}" }
  }
}
