{
  "my_conn": {
    "engine": "oracle",
    "user": "${DBA_MY_CONN_USER}",
    "password": "${DBA_MY_CONN_PASS}",
    "connectString": "${DBA_MY_CONN_CS}",
    "thick": false,
    "poolMax": 8,
    "readOnly": true,
    "schemaFilter": ["APP"]
  },
  "my_pg": {
    "engine": "postgres",
    "connectString": "${DBA_MY_PG_CS}",
    "poolMax": 8,
    "readOnly": true,
    "schemaFilter": ["public"]
  }
}
