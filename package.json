{
  "name": "dba-master",
  "version": "1.0.1",
  "description": "MCP server para introspecção profunda de bancos Oracle, voltado a consumo por agentes de IA",
  "type": "module",
  "bin": {
    "dba-master": "dist/src/index.js"
  },
  "main": "dist/src/index.js",
  "files": [
    "dist",
    "agents/commands"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test \"src/**/*.test.ts\" \"generator/**/*.test.ts\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "oracle",
    "oracledb",
    "dba",
    "schema",
    "introspection"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "@modelcontextprotocol/server": "^2.0.0-beta.1",
    "cfonts": "^3.3.1",
    "oracledb": "^7.0.0",
    "tsx": "^4.22.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/oracledb": "^7.0.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AdanEinstein/dba-master"
  },
  "contributors": [
    {
      "name": "AdanEinstein",
      "url": "https://github.com/AdanEinstein"
    }
  ]
}
