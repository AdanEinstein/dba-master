{
  "name": "dba-master",
  "version": "1.0.4",
  "description": "MCP server para introspecção profunda de bancos de dados (Oracle, PostgreSQL, MySQL/MariaDB), voltado a consumo por agentes de IA e LLMs",
  "type": "module",
  "bin": {
    "dba-master": "dist/src/index.js"
  },
  "main": "dist/src/index.js",
  "files": [
    "dist",
    "agents/commands"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test \"src/**/*.test.ts\" \"generator/**/*.test.ts\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "oracle",
    "oracledb",
    "postgres",
    "postgresql",
    "mysql",
    "mariadb",
    "dba",
    "schema",
    "database",
    "introspection",
    "ai",
    "llm",
    "claude"
  ],
  "author": "AdanEinstein",
  "license": "ISC",
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "@modelcontextprotocol/server": "^2.0.0-beta.1",
    "cfonts": "^3.3.1",
    "mysql2": "^3.22.5",
    "oracledb": "^7.0.0",
    "pg": "^8.22.0",
    "socks": "^2.8.9",
    "ssh2": "^1.17.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "tsx": "^4.22.4",
    "@types/node": "^26.1.0",
    "@types/oracledb": "^7.0.1",
    "@types/pg": "^8.20.0",
    "@types/ssh2": "^1.15.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AdanEinstein/dba-master.git"
  },
  "bugs": {
    "url": "https://github.com/AdanEinstein/dba-master/issues"
  },
  "homepage": "https://github.com/AdanEinstein/dba-master#readme",
  "contributors": [
    {
      "name": "AdanEinstein",
      "url": "https://github.com/AdanEinstein"
    }
  ]
}
