# Conexão (obrigatório)
DB_USER=meu_usuario
DB_PASSWORD=minha_senha
DB_CONNECT_STRING=host:1521/service_name

# Modo do driver: thin (default, JS puro, sem Instant Client) ou thick
DB_CLIENT_MODE=thin
# Só em thick, se as libs do client não estiverem no caminho padrão
# DB_CLIENT_LIB_DIR=/opt/oracle/instantclient_21_1

# Schemas a introspectar, separados por vírgula. Vazio = todos os schemas
# de usuário acessíveis (exclui schemas mantidos pela Oracle: SYS, SYSTEM...).
SCHEMA_FILTER=

# false libera escrita via run_sql (tool de iteração futura). Default: só leitura.
READ_ONLY=true

# Onde as interfaces .ts do cache são gravadas (default: ./.cache)
# CACHE_DIR=.cache
